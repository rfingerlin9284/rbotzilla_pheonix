{
  "version": "2.0.0",
  "options": {
    "shell": {
      "executable": "/bin/bash",
      "args": ["-c"]
    }
  },
  "tasks": [
    {
      "label": "🚀 Start Autonomous Engine (Headless)",
      "type": "shell",
      "command": "cd /home/rfing/RBOTZILLA_PHOENIX && bash scripts/rbot_ctl.sh start-auto",
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "new", "title": "RBOTZILLA Start" },
      "problemMatcher": []
    },

    {
      "label": "🔄 Reload & Apply Code Changes (Hot Restart)",
      "detail": "Stops bot → waits 3s → restarts with all latest code changes active. Bot re-syncs open positions from OANDA on startup — nothing is lost.",
      "type": "shell",
      "command": "cd /home/rfing/RBOTZILLA_PHOENIX && echo '⏹  Stopping bot...' && bash scripts/rbot_ctl.sh stop && sleep 3 && echo '🚀 Restarting with latest code...' && bash scripts/rbot_ctl.sh start-auto && echo '✅ Bot restarted. New code is now live.'",
      "presentation": { "reveal": "always", "panel": "new", "clear": true, "focus": true, "title": "🔄 Reload & Apply Changes" },
      "problemMatcher": []
    },

    {
      "label": "📡 Reconnect After Internet Loss",
      "detail": "Waits for OANDA API to come back online, then performs a clean restart. Run this whenever your connection drops and comes back.",
      "type": "shell",
      "command": "cd /home/rfing/RBOTZILLA_PHOENIX && TOKEN=$(grep -E '^OANDA_TOKEN=' .env | cut -d= -f2 | tr -d '\"') && echo '📡 Waiting for OANDA API to come back...' && until curl -sf --max-time 5 https://api-fxpractice.oanda.com/v3/instruments/EUR_USD/candles?count=1 -H \"Authorization: Bearer $TOKEN\" > /dev/null; do echo '  ⏳ Still offline — retrying in 15s...'; sleep 15; done && echo '✅ OANDA API is back online!' && bash scripts/rbot_ctl.sh stop && sleep 2 && bash scripts/rbot_ctl.sh start-auto && echo '✅ Bot reconnected and running.'",
      "presentation": { "reveal": "always", "panel": "new", "clear": true, "focus": true, "title": "📡 Reconnect" },
      "problemMatcher": []
    },

    {
      "label": "🛡️ Start Order Watchdog (Background Monitor)",
