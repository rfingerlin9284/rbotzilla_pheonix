# RBOTZILLA PHOENIX - Headless Runtime Environment
# Modes: PAPER, LIVE, BACKTEST (set with util.mode_manager.switch_mode)
# Brokers: OANDA + Coinbase Advanced only

# Headless controls
ENABLE_DASHBOARD=0
ENABLE_OANDA=1
ENABLE_COINBASE=0

# OANDA credentials
OANDA_PRACTICE_ACCOUNT_ID=YOUR_OANDA_PRACTICE_ACCOUNT_ID
OANDA_PRACTICE_TOKEN=YOUR_OANDA_PRACTICE_TOKEN
OANDA_LIVE_ACCOUNT_ID=YOUR_OANDA_LIVE_ACCOUNT_ID
OANDA_LIVE_TOKEN=YOUR_OANDA_LIVE_TOKEN

# Coinbase Advanced credentials
COINBASE_SANDBOX_API_KEY=YOUR_COINBASE_SANDBOX_API_KEY
COINBASE_SANDBOX_API_SECRET=YOUR_COINBASE_SANDBOX_API_SECRET
COINBASE_SANDBOX_PASSPHRASE=YOUR_COINBASE_SANDBOX_PASSPHRASE
COINBASE_LIVE_API_KEY=YOUR_COINBASE_LIVE_API_KEY
COINBASE_LIVE_API_SECRET=YOUR_COINBASE_LIVE_API_SECRET
COINBASE_LIVE_PASSPHRASE=YOUR_COINBASE_LIVE_PASSPHRASE

# Global trade limits
# 0 = no limit; set to a small integer to restrict trades per session per platform (safe testing)
BOT_MAX_TRADES=3
# .env.example - copy to .env and fill in
RICK_PIN=841921
RICK_DEV_MODE=1
RICK_AGGRESSIVE_PLAN=0
RICK_AGGRESSIVE_LEVERAGE=3
RICK_LEVERAGE_MAX=5
RICK_LEVERAGE_AGGRESSIVENESS=2

# OANDA (fill these for practice / live)
OANDA_API_BASE=https://api-fxpractice.oanda.com
OANDA_ACCOUNT_ID=YOUR_OANDA_ACCOUNT_ID
OANDA_TOKEN=YOUR_OANDA_TOKEN

# Optional
NARRATION_FILE_OVERRIDE=logs/narration.jsonl
POSITIONS_REGISTRY_FILE=/tmp/rick_positions_registry.json
RICK_ALLOW_CROSS_BROKER_DUPLICATES=0

# Micro-trade filtering (default: block micro trades)
# MIN_NET_PROFIT_USD: minimum expected net profit after estimated fees required to allow a trade
# MIN_RISK_PER_TRADE_USD: do not place orders where risk is below this USD-equivalent
# EST_FEE_RATE_BPS_OANDA/COINBASE: estimated round-trip fee rate in basis points used for fee estimation
# ALLOW_MICRO_TRADES: 0 = block, 1 = allow micro trades (bypass gate)
MIN_NET_PROFIT_USD=5.0
MIN_RISK_PER_TRADE_USD=5.0
EST_FEE_RATE_BPS_OANDA=1.5
EST_FEE_RATE_BPS_COINBASE=2.0
ALLOW_MICRO_TRADES=0
# Force automatic close if an attempted trailing stop update fails repeatedly (use with caution)
# 0 = do nothing on SL update failure, 1 = attempt to force-close the position
FORCE_CLOSE_ON_SL_UPDATE_FAILURE=0
# Hive consensus confidence threshold
# HIVE_TRIGGER_CONFIDENCE: Fraction 0..1 used to determine whether hive consensus is high enough to trigger TP->TRAILING conversion.
# Default is 0.60 to allow more signals in dev and personal setups; the system will enforce the Charter minimum (0.80) in production unless RICK_DEV_MODE=1.
HIVE_TRIGGER_CONFIDENCE=0.60

# Deterministic risk / stop policy defaults
RBOT_MAX_LOSS_USD_PER_TRADE=30
RBOT_ALLOW_EXTENDED_DOLLAR_STOP=0
RBOT_GREEN_LOCK_PIPS=1.5
RBOT_MAX_PAIRS_PER_PLATFORM=6
RBOT_MAX_ACTIVE_POSITIONS=6

# ========================= ALERTING & COMMUNICATION ==========================
# ALERT_PHONE_NUMBER: numeric phone # including country code (string)
ALERT_PHONE_NUMBER=+10000000000
# ALERT_EMAIL: email receiving notifications
ALERT_EMAIL=ops@example.com
SMS_GATEWAY=ops-sms@example.com
USER_PHONE_NUMBER=+10000000000

# TELEGRAM (Optional)
TELEGRAM_CHAT_ID=00000000
TELEGRAM_BOT_TOKEN=<SET_TELEGRAM_BOT_TOKEN>

# DISCORD Webhook
DISCORD_WEBHOOK_URL=<SET_DISCORD_WEBHOOK_URL>

# ========================= MARKET DATA API KEYS ==============================
CRYPTOPANIC_API_KEY=<SET_CRYPTOPANIC_API_KEY>
# Test flags for alerting (set to 1 to enable test sends for diagnostics)
TEST_ALERTING_SEND=0
TESTING_ALERT_SENT=0
# Reddit App credentials for market sentiment (set to actual values for testing only)
REDDIT_CLIENT_ID=<SET_REDDIT_CLIENT_ID>
REDDIT_CLIENT_SECRET=<SET_REDDIT_CLIENT_SECRET>
REDDIT_USER_AGENT=<SET_REDDIT_USER_AGENT>
REDDIT_SUBREDDITS=finance,news,cryptocurrency,forex,stockmarket

