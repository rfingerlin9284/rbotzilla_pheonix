# RBOTZILLA PHOENIX - Git Ignore File
# Purpose: Protect secrets, exclude runtime artifacts

# ═══════════════════════════════════════════════════════════════════════════
# 🔐 SECRETS & CREDENTIALS (CRITICAL - NEVER COMMIT)
# ═══════════════════════════════════════════════════════════════════════════
ops/secrets.env
ops/*.env
.env
.env.local
.env.*.local
env_new.env
.state/
master.env

# API Keys & Tokens
credentials.json
token.json
*.pem
*.key
private_key*
access_token*

# ═══════════════════════════════════════════════════════════════════════════
# 📝 RUNTIME LOGS & DATA (NOT PRODUCTION ARTIFACTS)
# ═══════════════════════════════════════════════════════════════════════════
logs/
audit_logs/
audit_reports/
status/
export/
archives/
*.log
/tmp/
/tmp.txt

# Event logs (sensitive trade data)
logs/narration.jsonl*
logs/oanda_headless.log
logs/parameter_changes.log
logs/strict_runtime_*.txt

# ═══════════════════════════════════════════════════════════════════════════
# 🐍 PYTHON (Virtual Environment, Cache, etc.)
# ═══════════════════════════════════════════════════════════════════════════
.venv/
venv/
env/
ENV/
*/venv/
**/venv/
venv_coinbase/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.c
*.so

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.hypothesis/

# ═══════════════════════════════════════════════════════════════════════════
# 💾 BACKUPS & TEMPORARY FILES
# ═══════════════════════════════════════════════════════════════════════════
backups/
*.bak
*.backup
*.tmp
*.swp
*.swo
*~
.*.swp
.DS_Store
_CONSOLIDATION_BACKUP_*/

# Backup narration files
logs/narration.jsonl.*
logs/narration.jsonl.backup

# Configuration backups
configs/runtime_mode.json.*
configs/*.backup

