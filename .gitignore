# ═══════════════════════════════════════════════════════════════════════════
# ✓ ALLOW PATTERNS (Override gitignore for important files)
# ═══════════════════════════════════════════════════════════════════════════
!README.md
!DEPLOYMENT.md
!ARCHITECTURE.md
!WORKFLOWS.md
!MEGA_PROMPT.md
!API_CHEATSHEET.md
!LICENSE
!.gitignore

# Source code (YES)
!*.py
!*.sh
!*.js
!*.json

# Configuration templates (YES)
!ops/secrets.env.template
!configs/runtime_mode.json.template
!.env.example

# VS Code tasks (YES)
!.vscode/tasks.json

# Examples & tests (YES)
!tests/
!examples/
!sample_data/

# Directory markers (YES)
!.gitkeep
!logs/.gitkeep
!backups/.gitkeep
